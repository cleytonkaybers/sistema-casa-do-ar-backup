# =============================================
# VARIÁVEIS DE AMBIENTE - CASA DO AR
# =============================================
# Copie este arquivo para .env.local e preencha com seus valores reais.
# Nunca commite o .env.local — ele já está no .gitignore.

# ID da aplicação no Base44 (obrigatório)
VITE_BASE44_APP_ID=seu_app_id_aqui

# URL base do backend Base44 (obrigatório)
VITE_BASE44_APP_BASE_URL=https://seu-app.base44.app

# Versão das funções serverless (opcional)
# VITE_BASE44_FUNCTIONS_VERSION=latest

# Base URL do Vite para deploy em subdiretório (ex: GitHub Pages)
# Deixe como "/" para deploy na raiz (Vercel, Netlify, domínio próprio)
# Use "/nome-do-repositorio/" para GitHub Pages em subpath
VITE_BASE_URL=/
